def timeout_decorator(seconds=30):
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            result = [None]
            exception = [None]
            
            def target():
                try:
                    result[0] = func(*args, **kwargs)
                except Exception as e:
                    exception[0] = e
            
            thread = threading.Thread(target=target, daemon=True)
            thread.start()
            thread.join(timeout=seconds)
            
            if thread.is_alive():
                logger.error(f"Function {func.__name__} timed out after {seconds}s")
                return None, f"Operation timed out after {seconds}s"
            
            if exception[0]:
                raise exception[0]
            
            return result[0]
        return wrapper
    return decorator

@contextmanager
def safe_lock(lock, timeout=5):
    acquired = lock.acquire(timeout=timeout)
    if not acquired:
        raise TimeoutError(f"Could not acquire lock within {timeout} seconds")
    try:
        yield
    finally:
        lock.release()

