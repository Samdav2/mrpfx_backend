@app.route('/health', methods=['GET'])
def health():
    try:
        with safe_lock(installations_lock, timeout=2):
            running_count = sum(1 for i in MT5_INSTALLATIONS.values() if i['status'] == 'running')

        with safe_lock(sessions_lock, timeout=2):
            active_sessions = len(sessions)

        with safe_lock(active_logins_lock, timeout=2):
            total_active_logins = sum(len(logins) for logins in active_logins.values())

        with safe_lock(disconnected_lock, timeout=2):
            total_disconnected = sum(len(accounts) for accounts in disconnected_accounts.values())

        return jsonify({
            'status': 'ok',
            'installations_running': running_count,
            'installations_total': len(MT5_INSTALLATIONS),
            'active_sessions': active_sessions,
            'total_active_logins': total_active_logins,
            'total_disconnected_accounts': total_disconnected,
            'timestamp': datetime.now().isoformat()
        })
    
    except TimeoutError:
        return jsonify({
            'status': 'degraded',
            'error': 'System busy',
            'timestamp': datetime.now().isoformat()
        }), 503
    except Exception as e:
        logger.error(f"Health check error: {e}")
        return jsonify({
            'status': 'error',
            'error': str(e),
            'timestamp': datetime.now().isoformat()
        }), 500

